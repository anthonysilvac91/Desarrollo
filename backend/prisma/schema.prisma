datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  WORKER
  CLIENT
}

enum ServiceStatus {
  COMPLETED
  ARCHIVED
}

enum WorkerEditPolicy {
  ALWAYS_OPEN
  UNTIL_ADMIN_INTERVENES
  UNTIL_PUBLISHED
  TIME_WINDOW
}

enum StoredFileVisibility {
  PUBLIC
  PRIVATE
}

enum StoredFileStatus {
  READY
  DELETING
  DELETED
  FAILED
}

enum StoredFileKind {
  ORG_LOGO
  USER_AVATAR
  ASSET_THUMBNAIL
  SERVICE_ATTACHMENT
  COMPANY_LOGO
}

model Organization {
  id        String  @id @default(uuid())
  name      String
  slug      String  @unique
  is_active Boolean @default(true)

  logo_file_id       String? @unique
  logo_url           String?
  brand_color        String?
  default_asset_icon String?

  auto_publish_services    Boolean          @default(true)
  worker_edit_policy       WorkerEditPolicy @default(TIME_WINDOW)
  worker_edit_window_hours Int?
  worker_restricted_access Boolean          @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  logo_file    StoredFile?  @relation("OrganizationLogoFile", fields: [logo_file_id], references: [id])
  users        User[]
  assets       Asset[]
  services     Service[]
  companies    Company[]
  invitations  Invitation[]
  stored_files StoredFile[]

  @@index([is_active])
  @@index([created_at])
}

model User {
  id                 String    @id @default(uuid())
  organization_id    String?
  role               Role
  email              String
  password_hash      String
  name               String
  phone              String?
  avatar_file_id     String?   @unique
  avatar_url         String?
  company_id         String?
  is_active          Boolean   @default(true)
  last_login_at      DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organization          Organization?       @relation(fields: [organization_id], references: [id])
  company               Company?            @relation(fields: [company_id], references: [id])
  avatar_file           StoredFile?         @relation("UserAvatarFile", fields: [avatar_file_id], references: [id])
  services_created      Service[]           @relation("ServiceWorker")
  worker_asset_access   WorkerAssetAccess[] @relation("GrantedToWorker")
  access_granted_w      WorkerAssetAccess[] @relation("GrantedByAdminW")
  invitations_sent      Invitation[]        @relation("InvitedBy")
  stored_files_uploaded StoredFile[]        @relation("StoredFileUploadedBy")

  @@unique([email, organization_id])
  @@index([organization_id])
  @@index([organization_id, created_at])
  @@index([organization_id, role])
  @@index([company_id])
  @@index([role])
  @@index([is_active])
}

model Asset {
  id                String  @id @default(uuid())
  organization_id   String
  name              String
  description       String?
  category          String?
  location          String?
  thumbnail_file_id String? @unique
  thumbnail_url     String?
  serial_number     String?
  company_id        String?
  is_active         Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organization   Organization        @relation(fields: [organization_id], references: [id])
  company        Company?            @relation(fields: [company_id], references: [id])
  thumbnail_file StoredFile?         @relation("AssetThumbnailFile", fields: [thumbnail_file_id], references: [id])
  services       Service[]
  worker_access  WorkerAssetAccess[]

  @@index([organization_id])
  @@index([organization_id, created_at])
  @@index([organization_id, company_id])
  @@index([company_id])
  @@index([is_active])
}

model Service {
  id               String        @id @default(uuid())
  organization_id  String
  asset_id         String
  worker_id        String
  title            String
  description      String?
  status           ServiceStatus @default(COMPLETED)
  is_public        Boolean       @default(false)
  admin_intervened Boolean       @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organization Organization        @relation(fields: [organization_id], references: [id])
  asset        Asset               @relation(fields: [asset_id], references: [id])
  worker       User                @relation("ServiceWorker", fields: [worker_id], references: [id])
  attachments  ServiceAttachment[]

  @@index([organization_id])
  @@index([organization_id, created_at])
  @@index([organization_id, asset_id])
  @@index([asset_id])
  @@index([asset_id, created_at])
  @@index([worker_id])
  @@index([worker_id, created_at])
  @@index([is_public])
  @@index([created_at])
}

model ServiceAttachment {
  id              String  @id @default(uuid())
  service_id      String
  file_id         String? @unique
  file_url        String?
  file_type       String?
  file_name       String?
  file_size_bytes Int?

  created_at DateTime @default(now())

  service Service     @relation(fields: [service_id], references: [id])
  file    StoredFile? @relation("ServiceAttachmentFile", fields: [file_id], references: [id])

  @@index([service_id])
}

model Company {
  id              String  @id @default(uuid())
  organization_id String
  name            String
  logo_file_id    String? @unique
  logo_url        String?
  is_active       Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id])
  logo_file    StoredFile?  @relation("CompanyLogoFile", fields: [logo_file_id], references: [id])
  users        User[]
  assets       Asset[]

  @@index([organization_id])
  @@index([organization_id, created_at])
  @@index([is_active])
}

model StoredFile {
  id                  String               @id @default(uuid())
  organization_id     String
  storage_ref         String               @unique
  original_name       String?
  mime_type           String?
  size_bytes          Int?
  kind                StoredFileKind
  visibility          StoredFileVisibility
  owner_type          String
  owner_id            String
  uploaded_by_user_id String?
  status              StoredFileStatus     @default(READY)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organization          Organization       @relation(fields: [organization_id], references: [id])
  uploaded_by           User?              @relation("StoredFileUploadedBy", fields: [uploaded_by_user_id], references: [id])
  organization_logo_for Organization?      @relation("OrganizationLogoFile")
  user_avatar_for       User?              @relation("UserAvatarFile")
  asset_thumbnail_for   Asset?             @relation("AssetThumbnailFile")
  company_logo_for      Company?           @relation("CompanyLogoFile")
  service_attachment    ServiceAttachment? @relation("ServiceAttachmentFile")

  @@index([organization_id])
  @@index([organization_id, kind])
  @@index([owner_type, owner_id])
  @@index([kind])
  @@index([status])
}

model WorkerAssetAccess {
  worker_id     String
  asset_id      String
  granted_by_id String?
  created_at    DateTime @default(now())

  worker     User  @relation("GrantedToWorker", fields: [worker_id], references: [id])
  asset      Asset @relation(fields: [asset_id], references: [id])
  granted_by User? @relation("GrantedByAdminW", fields: [granted_by_id], references: [id])

  @@id([worker_id, asset_id])
  @@index([worker_id])
  @@index([asset_id])
}

model Invitation {
  id              String   @id @default(uuid())
  organization_id String
  email           String
  role            Role
  token           String   @unique
  invited_by_id   String
  is_used         Boolean  @default(false)
  expires_at      DateTime

  created_at DateTime @default(now())

  organization Organization @relation(fields: [organization_id], references: [id])
  invited_by   User         @relation("InvitedBy", fields: [invited_by_id], references: [id])

  @@index([email, organization_id])
  @@index([token])
  @@index([is_used])
  @@index([expires_at])
}
