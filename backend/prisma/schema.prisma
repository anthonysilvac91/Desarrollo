datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  WORKER
  EXTERNAL
}

enum AssetAccessMode {
  UNRESTRICTED
  RESTRICTED
}

enum ServiceStatus {
  COMPLETED
  ARCHIVED
}

enum WorkerEditPolicy {
  ALWAYS_OPEN
  UNTIL_ADMIN_INTERVENES
  UNTIL_PUBLISHED
  TIME_WINDOW
}

enum StoredFileVisibility {
  PUBLIC
  PRIVATE
}

enum StoredFileStatus {
  READY
  DELETING
  DELETED
  FAILED
}

enum StoredFileKind {
  ORG_LOGO
  USER_AVATAR
  ASSET_THUMBNAIL
  SERVICE_ATTACHMENT
  OWNER_LOGO
}

enum UploadStatus {
  PENDING
  UPLOADING
  UPLOADED
  CONFIRMED
  FAILED
  EXPIRED
  CANCELLED
}

enum AttachmentMediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

enum ServiceAttachmentUploadStatus {
  NONE
  UPLOADING
  PARTIALLY_READY
  READY
  FAILED
}

enum EmailTokenType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
  TWO_FACTOR_CODE
}

enum TwoFactorMethod {
  APP
  EMAIL
}

enum PlanTier {
  DEMO
  STARTER
  PRO
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  SUSPENDED
  CANCELLED
}

model Organization {
  id        String  @id @default(uuid())
  name      String
  slug      String  @unique
  is_active Boolean @default(true)

  logo_file_id       String? @unique
  brand_color        String?
  default_asset_icon String?

  auto_publish_services    Boolean          @default(true)
  worker_edit_policy       WorkerEditPolicy @default(TIME_WINDOW)
  worker_edit_window_hours Int?
  show_org_name            Boolean          @default(false)
  video_uploads_enabled    Boolean          @default(false)
  storage_quota_bytes      BigInt?
  max_video_file_bytes     BigInt?
  upload_concurrency_limit Int              @default(2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  logo_file                     StoredFile?                  @relation("OrganizationLogoFile", fields: [logo_file_id], references: [id])
  users                         User[]
  assets                        Asset[]
  services                      Service[]
  owners                        Owner[]
  invitations                   Invitation[]
  stored_files                  StoredFile[]
  file_uploads                  FileUpload[]
  storage_usage                 OrganizationStorageUsage?
  storage_reconciliation_issues StorageReconciliationIssue[]
  subscription                  Subscription?
  worker_asset_access           WorkerAssetAccess[]

  @@index([is_active])
  @@index([created_at])
}

model Subscription {
  id              String             @id @default(uuid())
  organization_id String             @unique
  plan            PlanTier           @default(DEMO)
  status          SubscriptionStatus @default(TRIALING)

  max_users            Int     @default(3)
  max_assets           Int     @default(20)
  max_storage_gb       Float   @default(1.0)
  max_video_hours      Float   @default(0.0)
  allow_external       Boolean @default(false)
  allow_branding       Boolean @default(false)
  allow_ai_translation Boolean @default(false)

  demo_expires_at DateTime?

  pending_plan              PlanTier?
  pending_plan_requested_at DateTime?
  pending_plan_requested_by String?

  notes String?

  payment_status String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id])

  @@index([plan])
  @@index([status])
  @@index([demo_expires_at])
}

model User {
  id                      String          @id @default(uuid())
  organization_id         String?
  role                    Role
  email                   String          @unique
  password_hash           String
  name                    String
  phone                   String?
  avatar_file_id          String?         @unique
  owner_id                String?
  asset_access_mode       AssetAccessMode @default(UNRESTRICTED)
  is_active               Boolean         @default(true)
  two_factor_enabled      Boolean         @default(false)
  two_factor_method       TwoFactorMethod @default(APP)
  two_factor_secret       String?
  two_factor_backup_codes Json?
  last_login_at           DateTime?
  email_verified_at       DateTime?
  deleted_at              DateTime?
  deleted_by_id           String?
  purged_at               DateTime?
  purged_by_id            String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organization          Organization?       @relation(fields: [organization_id], references: [id])
  owner                 Owner?              @relation(fields: [owner_id], references: [id])
  deleted_by            User?               @relation("UserDeletedBy", fields: [deleted_by_id], references: [id])
  avatar_file           StoredFile?         @relation("UserAvatarFile", fields: [avatar_file_id], references: [id])
  services_created      Service[]           @relation("ServiceWorker")
  worker_asset_access   WorkerAssetAccess[] @relation("GrantedToWorker")
  access_granted_w      WorkerAssetAccess[] @relation("GrantedByAdminW")
  invitations_sent      Invitation[]        @relation("InvitedBy")
  stored_files_uploaded StoredFile[]        @relation("StoredFileUploadedBy")
  service_share_links   ServiceShareLink[]  @relation("ServiceShareLinkCreatedBy")
  file_uploads_created  FileUpload[]        @relation("FileUploadCreatedBy")
  email_tokens          EmailToken[]
  sessions              UserSession[]
  pending_totp_setup    PendingTotpSetup?
  users_deleted         User[]              @relation("UserDeletedBy")
  assets_deleted        Asset[]             @relation("AssetDeletedBy")
  services_deleted      Service[]           @relation("ServiceDeletedBy")
  owners_deleted        Owner[]             @relation("OwnerDeletedBy")

  @@unique([id, organization_id])
  @@index([organization_id])
  @@index([organization_id, created_at])
  @@index([organization_id, role])
  @@index([organization_id, role, is_active])
  @@index([owner_id])
  @@index([role])
  @@index([is_active])
  @@index([deleted_at])
  @@index([purged_at])
}

model UserSession {
  id              String    @id @default(uuid())
  user_id         String
  organization_id String?
  token_jti       String    @unique
  device_name     String?
  device_type     String?
  browser         String?
  os              String?
  user_agent      String?
  ip_address      String?
  country         String?
  region          String?
  city            String?
  first_seen_at   DateTime  @default(now())
  last_seen_at    DateTime  @default(now())
  revoked_at      DateTime?
  expires_at      DateTime

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, revoked_at])
  @@index([user_id, last_seen_at])
  @@index([organization_id])
  @@index([expires_at])
}

model Asset {
  id                String    @id @default(uuid())
  organization_id   String
  name              String
  description       String?
  category          String?
  location          String?
  thumbnail_file_id String?   @unique
  serial_number     String?
  owner_id          String
  is_active         Boolean   @default(true)
  deleted_at        DateTime?
  deleted_by_id     String?
  purged_at         DateTime?
  purged_by_id      String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organization   Organization        @relation(fields: [organization_id], references: [id])
  owner          Owner               @relation(fields: [owner_id, organization_id], references: [id, organization_id], onDelete: Restrict, onUpdate: Cascade, map: "Asset_owner_same_organization_fkey")
  deleted_by     User?               @relation("AssetDeletedBy", fields: [deleted_by_id], references: [id])
  thumbnail_file StoredFile?         @relation("AssetThumbnailFile", fields: [thumbnail_file_id], references: [id])
  services       Service[]
  worker_access  WorkerAssetAccess[]

  @@unique([id, organization_id])
  @@index([organization_id])
  @@index([organization_id, created_at])
  @@index([organization_id, owner_id])
  @@index([owner_id])
  @@index([is_active])
  @@index([deleted_at])
  @@index([purged_at])
}

model Service {
  id                       String                        @id @default(uuid())
  organization_id          String
  asset_id                 String
  worker_id                String
  title                    String
  description              String?
  description_language     String?
  status                   ServiceStatus                 @default(COMPLETED)
  is_public                Boolean                       @default(false)
  admin_intervened         Boolean                       @default(false)
  attachment_upload_status ServiceAttachmentUploadStatus @default(NONE)
  pending_attachment_count Int                           @default(0)
  failed_attachment_count  Int                           @default(0)
  ready_attachment_count   Int                           @default(0)
  attachment_bytes_total   BigInt                        @default(0)
  attachment_bytes_ready   BigInt                        @default(0)
  deleted_at               DateTime?
  deleted_by_id            String?
  purged_at                DateTime?
  purged_by_id             String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organization Organization         @relation(fields: [organization_id], references: [id])
  asset        Asset                @relation(fields: [asset_id, organization_id], references: [id, organization_id], onDelete: Restrict, onUpdate: Cascade, map: "Service_asset_same_organization_fkey")
  worker       User                 @relation("ServiceWorker", fields: [worker_id], references: [id])
  deleted_by   User?                @relation("ServiceDeletedBy", fields: [deleted_by_id], references: [id])
  attachments  ServiceAttachment[]
  file_uploads FileUpload[]
  share_links  ServiceShareLink[]
  translations ServiceTranslation[]

  @@index([organization_id])
  @@index([organization_id, created_at])
  @@index([organization_id, asset_id])
  @@index([organization_id, worker_id])
  @@index([organization_id, is_public])
  @@index([asset_id])
  @@index([asset_id, created_at])
  @@index([asset_id, is_public, created_at])
  @@index([worker_id])
  @@index([worker_id, created_at])
  @@index([is_public])
  @@index([created_at])
  @@index([deleted_at])
  @@index([purged_at])
}

model AiProviderSetting {
  id                               String    @id @default(uuid())
  provider                         String    @unique
  encrypted_api_key                String?
  api_key_hint                     String?
  model                            String    @default("gpt-5.4-nano")
  translations_enabled             Boolean   @default(false)
  translate_services_created_after DateTime?
  configured_by_user_id            String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model ServiceTranslation {
  id              String  @id @default(uuid())
  service_id      String
  field           String
  language        String
  source_hash     String
  source_language String?
  translated_text String
  status          String  @default("ready")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  service Service @relation(fields: [service_id], references: [id], onDelete: Cascade)

  @@unique([service_id, field, language])
  @@index([service_id])
  @@index([language])
  @@index([source_hash])
}

model ServiceShareLink {
  id                 String    @id @default(uuid())
  service_id         String
  token              String    @unique
  is_enabled         Boolean   @default(true)
  allow_downloads    Boolean   @default(true)
  expires_at         DateTime?
  created_by_user_id String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  service    Service @relation(fields: [service_id], references: [id], onDelete: Cascade)
  created_by User?   @relation("ServiceShareLinkCreatedBy", fields: [created_by_user_id], references: [id])

  @@index([service_id])
  @@index([token])
  @@index([is_enabled])
  @@index([expires_at])
}

model ServiceAttachment {
  id               String              @id @default(uuid())
  service_id       String
  upload_id        String?             @unique
  file_id          String?             @unique
  file_type        String?
  file_name        String?
  file_size_bytes  Int?
  media_type       AttachmentMediaType @default(IMAGE)
  duration_seconds Int?
  width            Int?
  height           Int?
  sort_order       Int                 @default(0)

  cf_image_id      String?
  cf_image_variant String?

  created_at DateTime @default(now())

  service Service     @relation(fields: [service_id], references: [id])
  upload  FileUpload? @relation(fields: [upload_id], references: [id])
  file    StoredFile? @relation("ServiceAttachmentFile", fields: [file_id], references: [id])

  @@index([service_id])
  @@index([service_id, media_type])
}

model FileUpload {
  id                 String @id @default(uuid())
  organization_id    String
  service_id         String
  created_by_user_id String

  storage_ref         String  @unique
  original_name       String
  declared_mime_type  String
  detected_mime_type  String?
  declared_size_bytes BigInt
  actual_size_bytes   BigInt?

  media_type AttachmentMediaType
  status     UploadStatus        @default(PENDING)

  signed_token_hash   String?
  upload_started_at   DateTime?
  upload_completed_at DateTime?
  confirmed_at        DateTime?
  expires_at          DateTime
  failure_reason      String?
  local_progress      Int       @default(0)

  cf_stream_uid             String?
  cf_stream_upload_url      String?
  cf_stream_status          String?
  cf_stream_ready_to_stream Boolean @default(false)
  cf_stream_duration        Float?
  cf_stream_thumbnail       String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organization Organization       @relation(fields: [organization_id], references: [id])
  service      Service            @relation(fields: [service_id], references: [id], onDelete: Cascade)
  created_by   User               @relation("FileUploadCreatedBy", fields: [created_by_user_id], references: [id])
  attachment   ServiceAttachment?

  @@index([organization_id, status])
  @@index([service_id])
  @@index([created_by_user_id])
  @@index([expires_at])
}

model OrganizationStorageUsage {
  organization_id      String    @id
  ready_bytes          BigInt    @default(0)
  reserved_bytes       BigInt    @default(0)
  ready_file_count     Int       @default(0)
  pending_upload_count Int       @default(0)
  reconciled_at        DateTime?
  updated_at           DateTime  @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id])
}

model MaintenanceJobLock {
  name         String   @id
  locked_until DateTime
  locked_by    String
  updated_at   DateTime @updatedAt
}

model UploadMaintenanceRun {
  id               String    @id @default(uuid())
  job_name         String
  status           String
  started_at       DateTime  @default(now())
  finished_at      DateTime?
  expired_count    Int       @default(0)
  reconciled_count Int       @default(0)
  issue_count      Int       @default(0)
  error_message    String?

  @@index([job_name, started_at])
  @@index([status])
}

model StorageReconciliationIssue {
  id              String    @id @default(uuid())
  organization_id String
  issue_type      String
  storage_ref     String?
  entity_type     String?
  entity_id       String?
  detail          String?
  resolved_at     DateTime?
  created_at      DateTime  @default(now())

  organization Organization @relation(fields: [organization_id], references: [id])

  @@index([organization_id, issue_type])
  @@index([resolved_at])
  @@index([created_at])
}

model Owner {
  id              String    @id @default(uuid())
  organization_id String
  name            String
  logo_file_id    String?   @unique
  is_active       Boolean   @default(true)
  deleted_at      DateTime?
  deleted_by_id   String?
  purged_at       DateTime?
  purged_by_id    String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organization Organization @relation(fields: [organization_id], references: [id])
  logo_file    StoredFile?  @relation("OwnerLogoFile", fields: [logo_file_id], references: [id])
  deleted_by   User?        @relation("OwnerDeletedBy", fields: [deleted_by_id], references: [id])
  users        User[]
  assets       Asset[]

  @@unique([id, organization_id])
  @@index([organization_id])
  @@index([organization_id, created_at])
  @@index([is_active])
  @@index([deleted_at])
  @@index([purged_at])
}

model StoredFile {
  id                  String               @id @default(uuid())
  organization_id     String
  storage_ref         String               @unique
  original_name       String?
  mime_type           String?
  size_bytes          Int?
  kind                StoredFileKind
  visibility          StoredFileVisibility
  entity_type         String
  entity_id           String
  uploaded_by_user_id String?
  status              StoredFileStatus     @default(READY)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  organization          Organization       @relation(fields: [organization_id], references: [id])
  uploaded_by           User?              @relation("StoredFileUploadedBy", fields: [uploaded_by_user_id], references: [id])
  organization_logo_for Organization?      @relation("OrganizationLogoFile")
  user_avatar_for       User?              @relation("UserAvatarFile")
  asset_thumbnail_for   Asset?             @relation("AssetThumbnailFile")
  owner_logo_for        Owner?             @relation("OwnerLogoFile")
  service_attachment    ServiceAttachment? @relation("ServiceAttachmentFile")

  @@index([organization_id])
  @@index([organization_id, kind])
  @@index([entity_type, entity_id])
  @@index([kind])
  @@index([status])
}

model WorkerAssetAccess {
  worker_id       String
  asset_id        String
  organization_id String
  granted_by_id   String?
  created_at      DateTime @default(now())

  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Restrict, onUpdate: Cascade)
  worker       User         @relation("GrantedToWorker", fields: [worker_id, organization_id], references: [id, organization_id], onDelete: Restrict, onUpdate: Cascade, map: "WorkerAssetAccess_worker_org_fkey")
  asset        Asset        @relation(fields: [asset_id, organization_id], references: [id, organization_id], onDelete: Restrict, onUpdate: Cascade, map: "WorkerAssetAccess_asset_org_fkey")
  granted_by   User?        @relation("GrantedByAdminW", fields: [granted_by_id], references: [id])

  @@id([worker_id, asset_id])
  @@index([worker_id])
  @@index([asset_id])
  @@index([organization_id])
}

model Invitation {
  id                 String          @id @default(uuid())
  organization_id    String
  email              String
  role               Role
  token              String          @unique
  invited_by_id      String
  owner_id           String?
  asset_access_mode  AssetAccessMode @default(UNRESTRICTED)
  pending_asset_ids  String[]        @default([])
  is_used            Boolean         @default(false)
  expires_at         DateTime

  created_at DateTime @default(now())

  organization Organization @relation(fields: [organization_id], references: [id])
  invited_by   User         @relation("InvitedBy", fields: [invited_by_id], references: [id])

  @@index([email, organization_id])
  @@index([token])
  @@index([is_used])
  @@index([expires_at])
}

model EmailToken {
  id         String         @id @default(uuid())
  user_id    String
  type       EmailTokenType
  token      String         @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime       @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([token])
  @@index([expires_at])
}

model PendingTotpSetup {
  id               String    @id @default(uuid())
  user_id          String    @unique
  encrypted_secret String
  expires_at       DateTime
  created_at       DateTime  @default(now())
  consumed_at      DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
}
