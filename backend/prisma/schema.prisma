datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  SUPER_ADMIN  // Cuenta maestra de Recall. No pertenece a ninguna organización.
  ADMIN        // Administrador de una organización.
  WORKER       // Operario / trabajador de una organización.
  CLIENT       // Cliente final de una organización.
}

enum ServiceStatus {
  COMPLETED
  ARCHIVED
}

enum WorkerEditPolicy {
  ALWAYS_OPEN             // El worker siempre puede editar su service.
  UNTIL_ADMIN_INTERVENES  // Solo antes de que un admin lo modifique.
  UNTIL_PUBLISHED         // Solo mientras is_public = false.
  TIME_WINDOW             // Solo durante N horas desde la creación.
}

// ─────────────────────────────────────────
// ORGANIZATION — Tenant raíz del sistema
// ─────────────────────────────────────────

model Organization {
  id                        String           @id @default(uuid())
  name                      String
  slug                      String           @unique  // Identificador URL único (ej: marina-azul)
  is_active                 Boolean          @default(true)

  // Branding
  logo_url                  String?
  brand_color               String?          // Hex (ej: #1a73e8) para personalización UI

  // Configuración de services
  auto_publish_services     Boolean          @default(true)
  worker_edit_policy        WorkerEditPolicy @default(TIME_WINDOW)
  worker_edit_window_hours  Int?

  // Control de acceso de workers
  // false = workers ven todos los assets (default MVP)
  // true  = workers solo ven assets asignados en WorkerAssetAccess
  worker_restricted_access  Boolean          @default(false)

  created_at                DateTime         @default(now())
  updated_at                DateTime         @updatedAt

  // Relaciones
  users           User[]
  assets          Asset[]
  services        Service[]
  invitations     Invitation[]

  @@index([is_active])
}

// ─────────────────────────────────────────
// USER — Todos los actores del sistema
// ─────────────────────────────────────────

model User {
  id               String    @id @default(uuid())
  organization_id  String?   // NULL si el role es SUPER_ADMIN
  role             Role
  email            String
  password_hash    String
  name             String
  phone            String?
  avatar_url       String?
  is_active        Boolean   @default(true)
  last_login_at    DateTime?

  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  // Relaciones
  organization        Organization?       @relation(fields: [organization_id], references: [id])
  services_created    Service[]           @relation("ServiceWorker")
  client_asset_access ClientAssetAccess[] @relation("GrantedToClient")
  worker_asset_access WorkerAssetAccess[] @relation("GrantedToWorker")
  access_granted_c    ClientAssetAccess[] @relation("GrantedByAdminC")
  access_granted_w    WorkerAssetAccess[] @relation("GrantedByAdminW")
  invitations_sent    Invitation[]        @relation("InvitedBy")

  // Email único dentro de la organización.
  // SUPER_ADMIN: organization_id es null → unicidad global gestionada a nivel de app.
  @@unique([email, organization_id])
  @@index([organization_id])
  @@index([role])
  @@index([is_active])
}

// ─────────────────────────────────────────
// ASSET — Activo gestionado por una org
// ─────────────────────────────────────────

model Asset {
  id               String   @id @default(uuid())
  organization_id  String
  name             String
  description      String?
  category         String?        // boat, car, machinery, building, etc.
  location         String?        // Ubicación textual o coordenadas
  thumbnail_url    String?
  serial_number    String?        // Número de serie o matrícula (opcional)
  is_active        Boolean  @default(true)

  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Relaciones
  organization    Organization        @relation(fields: [organization_id], references: [id])
  services        Service[]
  client_access   ClientAssetAccess[]
  worker_access   WorkerAssetAccess[]

  @@index([organization_id])
  @@index([is_active])
}

// ─────────────────────────────────────────
// SERVICE — Registro central de intervenciones
// ─────────────────────────────────────────

model Service {
  id               String        @id @default(uuid())
  organization_id  String        // Desnormalizado intencionalmente para queries multi-tenant eficientes
  asset_id         String
  worker_id        String
  title            String
  description      String?
  status           ServiceStatus @default(COMPLETED)
  is_public        Boolean       @default(false) // El backend resuelve esto desde auto_publish_services
  admin_intervened Boolean       @default(false) // Flag cuando un admin modifica post-creación

  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  // Relaciones
  organization   Organization      @relation(fields: [organization_id], references: [id])
  asset          Asset             @relation(fields: [asset_id], references: [id])
  worker         User              @relation("ServiceWorker", fields: [worker_id], references: [id])
  attachments    ServiceAttachment[]

  @@index([organization_id])
  @@index([asset_id])
  @@index([worker_id])
  @@index([is_public])
  @@index([created_at])
}

// ─────────────────────────────────────────
// SERVICE ATTACHMENT — Archivos de evidencia
// ─────────────────────────────────────────

model ServiceAttachment {
  id              String   @id @default(uuid())
  service_id      String
  file_url        String
  file_type       String?          // MIME type (image/jpeg, application/pdf…)
  file_name       String?          // Nombre original del archivo
  file_size_bytes Int?             // Tamaño en bytes

  created_at      DateTime @default(now())

  service Service @relation(fields: [service_id], references: [id])

  @@index([service_id])
}

// ─────────────────────────────────────────
// CLIENT ASSET ACCESS — Visibilidad de clientes
// ─────────────────────────────────────────
// Un cliente solo ve los assets que le fueron asignados explícitamente.

model ClientAssetAccess {
  client_id     String
  asset_id      String
  granted_by_id String?  // Admin que otorgó el acceso
  created_at    DateTime @default(now())

  client     User   @relation("GrantedToClient", fields: [client_id], references: [id])
  asset      Asset  @relation(fields: [asset_id], references: [id])
  granted_by User?  @relation("GrantedByAdminC", fields: [granted_by_id], references: [id])

  @@id([client_id, asset_id])
  @@index([client_id])
  @@index([asset_id])
}

// ─────────────────────────────────────────
// WORKER ASSET ACCESS — Visibilidad de workers (restricción opcional)
// ─────────────────────────────────────────
// Se activa solo si Organization.worker_restricted_access = true.
// Mientras sea false, los workers ven todos los assets de su org por defecto.

model WorkerAssetAccess {
  worker_id     String
  asset_id      String
  granted_by_id String?  // Admin que otorgó el acceso
  created_at    DateTime @default(now())

  worker     User   @relation("GrantedToWorker", fields: [worker_id], references: [id])
  asset      Asset  @relation(fields: [asset_id], references: [id])
  granted_by User?  @relation("GrantedByAdminW", fields: [granted_by_id], references: [id])

  @@id([worker_id, asset_id])
  @@index([worker_id])
  @@index([asset_id])
}

// ─────────────────────────────────────────
// INVITATION — Registro por invitación segura
// ─────────────────────────────────────────
// Permite onboarding controlado. El invitado llega con token que pre-asigna org y rol.
// SUPER_ADMIN no se invita por este mecanismo.

model Invitation {
  id              String   @id @default(uuid())
  organization_id String
  email           String
  role            Role     // Solo ADMIN, WORKER o CLIENT. SUPER_ADMIN queda excluido por lógica de app.
  token           String   @unique  // Token seguro (UUID v4 / CSPRNG hex)
  invited_by_id   String
  is_used         Boolean  @default(false)
  expires_at      DateTime

  created_at      DateTime @default(now())

  organization Organization @relation(fields: [organization_id], references: [id])
  invited_by   User         @relation("InvitedBy", fields: [invited_by_id], references: [id])

  @@index([email, organization_id])
  @@index([token])
  @@index([is_used])
  @@index([expires_at])
}
