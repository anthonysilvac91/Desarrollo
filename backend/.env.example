# -----------------------------------------------------------------------------
# RECALL BACKEND - ENV EXAMPLE
# -----------------------------------------------------------------------------

# DATABASE (Usar postgres local via Docker)
# Local: postgresql://postgres:postgres@localhost:5432/recall_local?schema=public
DATABASE_URL="postgresql://user:pass@localhost:5432/db_name?schema=public"

# AUTH
JWT_SECRET="your_very_secret_key_here"

# APP CONFIG
PORT=4000

# STORAGE (LOCAL / SUPABASE)
# Para desarrollo local se recomienda 'local'
STORAGE_TYPE="local" 

# FRONTEND URL (Para CORS)
FRONTEND_URL="http://localhost:3000"
