# Entorno de Node
NODE_ENV=development

# Puerto del servidor backend
PORT=3000

# Conexión principal de Base de Datos PostgreSQL
DATABASE_URL=

# Llave semilla para el cifrado JWT (Debería tener al menos 32 caracteres seguros en producción)
JWT_SECRET=

# Configuración de Almacenamiento (local | supabase)
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
BASE_URL=http://localhost:3000

# Configuración de Supabase (Solo si STORAGE_TYPE=supabase)
# SUPABASE_URL=
# SUPABASE_KEY=
# SUPABASE_BUCKET=recall-attachments
