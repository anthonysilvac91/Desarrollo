# -----------------------------------------------------------------------------
# RECALL BACKEND - ENV EXAMPLE
# -----------------------------------------------------------------------------

# DATABASE (Configuracion local oficial con backend/docker-compose.yml)
DATABASE_URL="postgresql://recall_user:recall_password@localhost:5433/recall_mvp?schema=public"
DIRECT_URL="postgresql://recall_user:recall_password@localhost:5433/recall_mvp?schema=public"

# AUTH
JWT_SECRET="your_very_secret_key_here"

# APP CONFIG
PORT=3001

# STORAGE (LOCAL / SUPABASE)
# Para desarrollo local se recomienda 'local'
STORAGE_TYPE="local" 
UPLOAD_DIR="./uploads"
BASE_URL="http://localhost:3001"

# FRONTEND URL (Para CORS)
FRONTEND_URL="http://localhost:3000"
