# Entorno de Node
NODE_ENV=development

# Puerto del servidor backend
PORT=3001

# Conexión principal de Base de Datos PostgreSQL
# Reemplazar usuario, contraseña, dominio, puerto y nombre de BD
DATABASE_URL="postgresql://recall_user:recall_password@localhost:5432/recall_mvp?schema=public"

# Llave semilla para el cifrado JWT (Debería tener al menos 32 caracteres seguros en producción)
JWT_SECRET="PLEASE_CHANGE_ME_IN_PRODUCTION"
