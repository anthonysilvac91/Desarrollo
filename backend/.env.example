# -----------------------------------------------------------------------------
# FENTRI BACKEND - ENV EXAMPLE
# -----------------------------------------------------------------------------

# DATABASE (Configuracion local oficial con backend/docker-compose.yml)
DATABASE_URL="postgresql://fentri_user:fentri_password@localhost:5433/fentri_mvp?schema=public"
DIRECT_URL="postgresql://fentri_user:fentri_password@localhost:5433/fentri_mvp?schema=public"

# AUTH
JWT_SECRET="your_very_secret_key_here"

# APP CONFIG
PORT=3001

# STORAGE (LOCAL / SUPABASE)
# Para desarrollo local se recomienda 'local'
STORAGE_TYPE="local" 
UPLOAD_DIR="./uploads"
BASE_URL="http://localhost:3001"

# FRONTEND URL (para CORS y para construir links en emails)
# En producción: URL real de Vercel u otro host
FRONTEND_URL="http://localhost:3000"

# Email / Resend
# RESEND_API_KEY: obtener en resend.com — dejar vacío para deshabilitar emails en dev
RESEND_API_KEY=
# EMAIL_FROM: dirección de envío verificada en Resend
# Ejemplo temporal: contact@coremetricsmedia.com (cambiar cuando exista dominio definitivo de Fentri)
# El dominio debe estar verificado en Resend antes de usarlo en producción
EMAIL_FROM=contact@coremetricsmedia.com
# EMAIL_FROM_NAME: nombre visible del remitente
EMAIL_FROM_NAME=Fentri
